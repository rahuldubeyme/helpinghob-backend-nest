{
  "name": "helpinghob-api",
  "version": "1.0.0",
  "description": "HelpingHob Backend API",
  "author": "",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "build": "nest build",
    "format": "prettier --write \"{src,common,shared}/**/*.ts\"",
    "lint": "eslint \"{src,common,shared}/**/*.ts\" --fix",
    "test": "jest --passWithNoTests",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/cache-manager": "^3.1.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.0.1",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mongoose": "^11.0.4",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/platform-socket.io": "^11.1.11",
    "@nestjs/schedule": "^6.1.1",
    "@nestjs/swagger": "^11.2.3",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.11",
    "aws-sdk": "^2.1693.0",
    "bcrypt": "^6.0.0",
    "cache-manager": "^7.2.7",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.3",
    "compression": "^1.8.1",
    "ejs": "^4.0.1",
    "firebase-admin": "^13.7.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "ioredis": "^5.8.2",
    "mongoose": "^8.23.0",
    "nestjs-i18n": "^10.6.0",
    "nodemailer": "^7.0.12",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.0",
    "twilio": "^5.12.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@swc/cli": "^0.7.10",
    "@swc/core": "^1.15.11",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/ejs": "^3.1.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.7",
    "@types/nodemailer": "^7.0.5",
    "@types/sanitize-html": "^2.16.0",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.2.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": ".",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "./coverage",
    "testEnvironment": "node",
    "roots": ["<rootDir>/src/modules/"],
    "moduleNameMapper": {
      "^@common/(.*)$": "<rootDir>/common/$1",
      "^@shared/(.*)$": "<rootDir>/shared/$1",
      "^@config/(.*)$": "<rootDir>/src/config/$1",
      "^@mongodb/(.*)$": "<rootDir>/shared/mongodb/$1",
      "^@cache/(.*)$": "<rootDir>/shared/redis/$1",
      "^@swagger/(.*)$": "<rootDir>/shared/swagger/$1",
      "^@mail/(.*)$": "<rootDir>/shared/mail/$1",
      "^@decorators/(.*)$": "<rootDir>/common/decorators/$1",
      "^@filters/(.*)$": "<rootDir>/common/filters/$1",
      "^@guards/(.*)$": "<rootDir>/common/guards/$1",
      "^@interceptors/(.*)$": "<rootDir>/common/interceptors/$1",
      "^@interfaces/(.*)$": "<rootDir>/common/interfaces/$1",
      "^@middleware/(.*)$": "<rootDir>/common/middleware/$1",
      "^@modules/(.*)$": "<rootDir>/src/modules/$1",
      "^@pipes/(.*)$": "<rootDir>/common/pipes/$1",
      "^@rate-limit/(.*)$": "<rootDir>/shared/rate-limit/$1",
      "^@socket/(.*)$": "<rootDir>/shared/socket/$1",
      "^@i18n/(.*)$": "<rootDir>/shared/i18n/$1",
      "^@utils/(.*)$": "<rootDir>/common/utils/$1"
    }
  },
  "overrides": {
    "diff": "^8.0.4"
  }
}
