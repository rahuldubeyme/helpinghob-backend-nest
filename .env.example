# ── Server ────────────────────────────────────────────────────────────────────
SERVER_MODE=http                  # http | https
PORT=5000
NODE_ENV=development              # development | production

# SSL (only when SERVER_MODE=https)
SSL_KEY_PATH=
SSL_CERT_PATH=
SSL_CA_PATH=

# ── CORS ──────────────────────────────────────────────────────────────────────
SITE_URL=https://yourdomain.com
WEB_URL=https://admin.yourdomain.com

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_SECRET_TEMP=REPLACE_WITH_DIFFERENT_STRONG_SECRET
JWT_EXPIRES_IN=7d
OTP_VALID_MINUTES=15

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URI=mongodb://localhost:27017/helpinghob

# ── AWS S3 ────────────────────────────────────────────────────────────────────
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-south-1
AWS_S3_BUCKET=
AWS_S3_FOLDER=
S3_URL=
AWS_S3_BASE=

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USER=
MAIL_PASS=
MAIL_FROM=HelpingHob <no-reply@helpinghob.com>

# ── Twilio (SMS/OTP) ──────────────────────────────────────────────────────────
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── Google Maps ───────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=
